# ==============================================================================
# settings.local.yaml (사용자 개인 설정 오버라이드)
# ==============================================================================
#
# [중요] 이 파일은 .gitignore에 의해 공유되지 않습니다.
#        팀원마다 각자 자신의 환경에 맞게 작성하세요.
#        settings.yaml의 모든 키를 오버라이드할 수 있습니다.
#
# [사용법] 이 파일을 복사하여 settings.local.yaml로 저장하세요:
#   cp .agents/templates/settings.local.yaml.example .agents/settings.local.yaml
#
# ==============================================================================

# 에이전트 응답 언어 (settings.yaml의 기본값을 여기서 변경 가능)
# agent_behavior:
#   language: "en"   # 영어로 변경하려면 주석 해제

# ==============================================================================
# 프로젝트별 프레임워크 목록 (preferred_frameworks: auto 대신 직접 지정)
# ==============================================================================
# project_preferences:
#   preferred_frameworks:
#     - "React"
#     - "TypeScript"
#     - "Spring Boot"
#     - "Unity"
#     - "Python"
#     - "Docker"

# ==============================================================================
# 인덱싱 및 하이브리드 검색 설정 (Indexing Rules)
# ==============================================================================
# 팀 공통 구조와 다를 경우, 아래 주석을 해제하고 실제 경로 및 설정을 입력하세요.
# indexing_rules:
#   # 로컬 전용 유휴 시간 설정 (지정된 초 동안 요청이 없으면 워커 자동 종료)
#   # idle_timeout: 300
#
#   # 특정 경로 인덱싱에서 제외
#   # exclude_paths:
#   #   - "personal_notes/**"
#
#   # 모노레포 모듈 경로 정의 (내 프로젝트 구조에 맞게 수정)
#   # modules:
#   #   backend: ["BE/src/main/java"]
#   #   frontend: ["FE/src", "FE/public"]
#   #   ai: ["AI/apps", "AI/scripts"]
#   #   unity: ["Assets/Scripts"]
#
#   # 다른 프로젝트와 연동 (linked_workspaces)
#   # linked_workspaces:
#   #   - "../other-project"



