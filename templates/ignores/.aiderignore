# .geminiignore
# Ignore directories to prevent context bloat in Gemini CLI
.cortex/data/
.cortex/history/
.cortex/knowledge/
.cortex/.venv/
.cortex/venv/
.cortex/docs/
.cortex/.env
**/__pycache__/
.cortex/PROGRESS.md
.cortex/AGENTS.md
.cortex/INSTALL.md
.cortex/DEPENDENCIES.md
.cortex/LICENSE
.cortex/README.md
.cortex/requirements.txt

# Consolidated Context Folder (available via RAG indexing instead)
.reference/*

